# Beispiel-Konfigurationsdatei für das Bonusprogramm
# Kopieren Sie diese Datei nach `.env` und passen Sie die Werte an Ihre Umgebung an.

# Geheimer Admin‑Code zur Vergabe von Administratorrechten bei der Registrierung
ADMIN_CODE=MEIN_ADMIN_CODE

# Basis-URL für das Frontend (optional für Tests)
WEB_BASE_URL=http://localhost:3000

# Basis-URL für die API (optional für Tests)
API_BASE_URL=http://localhost:3000
